# AI features (optional) — the SQL "Ask in plain English" and the validator
# "Explain & fix" summary call a model server-side. Without a key the app works
# fully; those two buttons just show a "not configured" notice.
#
# Local dev: copy to .env.local (gitignored; Vite loads it) and fill in ONE option.
# On Vercel: add the same var(s) as project environment variables.
#
# Provider-agnostic — pick one:

# Option A — Anthropic (default, first-class)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-opus-4-8        # optional override
# ANTHROPIC_BASE_URL=                    # optional (proxy / Claude on AWS)

# Option B — Groq (OpenAI-compatible, free tier)
# GROQ_API_KEY=gsk_...
# AI_MODEL=llama-3.3-70b-versatile       # optional override

# Option C — any other OpenAI-compatible endpoint (OpenRouter, Together, Ollama…)
# AI_API_KEY=...
# AI_BASE_URL=https://api.groq.com/openai/v1
# AI_MODEL=llama-3.3-70b-versatile
