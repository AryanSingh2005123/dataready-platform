# AI features (optional) — the SQL "Ask in plain English" and the validator
# "Explain & fix" summary call Claude server-side. Without a key the app works
# fully; those two buttons just show a "not configured" notice.
#
# Local dev: copy to .env.local (Vite loads it) OR export in your shell before
# `npm run dev`. On Vercel: add ANTHROPIC_API_KEY as a project env var.

ANTHROPIC_API_KEY=

# Optional overrides
# ANTHROPIC_MODEL=claude-opus-4-8
# ANTHROPIC_BASE_URL=https://api.anthropic.com
